    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    
    <style>
        /* --- DROPDOWN CSS --- */
        
        /* Parent Container - Fixed Alignment */
        .nav-item-dropdown {
            position: relative;
            display: inline-block; /* Ensures it aligns with other links */
            height: auto;
        }

        /* The Dropdown Box */
        .dropdown-menu {
            position: absolute;
            top: 100%; /* Position right below the nav item */
            left: 50%;
            transform: translateX(-50%) translateY(20px) scale(0.95); /* Start lower and slightly smaller */
            width: 240px;
            background: rgba(14, 27, 19, 0.95); /* Deep dark theme color */
            backdrop-filter: blur(20px); /* Heavy glass blur */
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 10px 0;
            opacity: 0;
            visibility: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Cinematic Spring Effect */
            z-index: 1000;
            list-style: none;
            margin-top: 10px; /* Small gap to prevent accidental closing */
        }

        /* Show Dropdown on Hover */
        .nav-item-dropdown:hover .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0) scale(1); /* Slide up to position */
        }

        /* Dropdown Items */
        .dropdown-menu li {
            display: block;
            margin: 0;
            width: 100%;
        }

        .dropdown-menu li a {
            display: block;
            padding: 12px 25px;
            color: #ccc;
            font-family: 'Poppins', sans-serif; 
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s ease;
            text-align: center; 
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            white-space: nowrap; /* Prevent text wrapping */
        }

        .dropdown-menu li:last-child a {
            border-bottom: none;
        }

        /* Hover Effect for Items */
        .dropdown-menu li a:hover {
            color: #d4a017; /* Gold Color */
            background: rgba(255, 255, 255, 0.05);
            padding-left: 35px; /* Subtle slide right interaction */
            padding-right: 15px;
        }

        /* Highlight "All Products" differently */
        .dropdown-menu li:first-child a {
            font-weight: 600;
            color: #fff;
            background: rgba(255, 255, 255, 0.02);
        }
        .dropdown-menu li:first-child a:hover {
            background: rgba(212, 160, 23, 0.1);
            color: #d4a017;
        }

        /* Small arrow on top of dropdown */
        .dropdown-menu::before {
            content: '';
            position: absolute;
            top: -6px;
            left: 50%;
            transform: translateX(-50%) rotate(45deg);
            width: 12px;
            height: 12px;
            background: rgba(14, 27, 19, 0.95);
            border-left: 1px solid rgba(255,255,255,0.1);
            border-top: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>
