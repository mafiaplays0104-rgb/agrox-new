            <li class="mobile-dropdown-parent">
                <div class="mobile-dropdown-toggle">PRODUCTS <i class="fa-solid fa-chevron-down" style="font-size:0.75rem; margin-left: 4px;"></i></div>
                <ul class="mobile-dropdown-menu">
                    <li><a href="<?php echo $path; ?>all-products.php" class="mobile-link">All Products</a></li>
