    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const path = window.location.pathname;
            // Activate nav if not on homepage
            if (!path.includes("index.php") && path !== "/" && !path.endsWith("/")) {
                const nav = document.getElementById('navbar');
                if(nav) {
                    nav.classList.add('active');
                    nav.style.background = '#0e1b13';
                }
            }

            // Mobile Menu Toggle
            const hamburger = document.getElementById('hamburger-menu');
            const mobileMenu = document.getElementById('nav-menu-mobile');
            if (hamburger && mobileMenu) {
                hamburger.addEventListener('click', function() {
                    hamburger.classList.toggle('active');
                    mobileMenu.classList.toggle('active');
                    document.body.style.overflow = mobileMenu.classList.contains('active') ? 'hidden' : '';
                });

                document.querySelectorAll('.mobile-link').forEach(link => {
                    link.addEventListener('click', function() {
                        hamburger.classList.remove('active');
                        mobileMenu.classList.remove('active');
                        document.body.style.overflow = '';
                    });
                });
            }

            // Mobile Dropdown Products Toggle
            const mobileToggle = document.querySelector('.mobile-dropdown-toggle');
            const mobileParent = document.querySelector('.mobile-dropdown-parent');
            if (mobileToggle && mobileParent) {
                mobileToggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    mobileParent.classList.toggle('active');
                });
            }
        });
    </script>